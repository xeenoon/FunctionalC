# Project layout:
#   /core/src     runtime sources
#   /core/tools   compiler/codegen sources
#   /testdata     checked-in DSL examples
#   /out          generated C, binaries, and benchmark outputs

# Native build outputs
*.dll
*.obj
*.o
*.out
*.a
*.lib
*.pdb

# Root-level historical artifacts
*.exe
generated_*.c

# Benchmark artifacts and datasets
benchmarks/*.exe
benchmarks/**/*.exe
benchmarks/data/
benchmarks/_wt_0fb6070/
benchmarks/_wt_0fb6070/benchmarks/data/

# Generated output directory
core/out/*
!core/out/.gitkeep

# Common temp files
*.tmp
*.log
*.bak
*.orig

# Python stuff
.venv/
__pycache__/

# NPM packages
node_modules/

# Outputted files
*_O1
*_O2
*_O3

# Coding agents
.codex
/out
