{
    // Editor
    "editor.formatOnSave": true,
    "editor.rulers": [80],

    // Python
    "python.defaultInterpreterPath": "${workspaceFolder}/tests/.venv/bin/python",
    "python.analysis.typeCheckingMode": "basic",
    "python.testing.pytestEnabled": true,
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff"
    },
    "ruff.configuration": "${workspaceFolder}/tests/pyproject.toml"
}